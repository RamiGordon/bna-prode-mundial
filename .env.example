# =============================================================================
# Prode Mundial 2026 — Template de variables de entorno
# =============================================================================
#
# Para desarrollo local:
#   1. Copiá este archivo a .env.local (`cp .env.example .env.local`)
#   2. Completá los valores reales desde el dashboard de Supabase.
#   3. .env.local está ignorado por git — no se commitea nunca.
#
# Para deploy en Vercel:
#   Solo se cargan las 3 vars marcadas con [VERCEL] en este archivo.
#   El resto (DATABASE_URL, SUPA_REF) son sólo para tooling local.
#
# Nomenclatura: usamos las API keys nuevas de Supabase (sb_publishable_* /
# sb_secret_*), no las viejas (anon JWT / service_role JWT).
# =============================================================================


# --- Supabase JS client (runtime de la app) ----------------------------------

# [VERCEL] URL del proyecto Supabase. Pública.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# [VERCEL] Publishable key — se envía al browser. Respeta RLS, sólo lee/escribe
# lo que las policies permiten al usuario autenticado.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# [VERCEL] Secret key — server-only. Bypassea RLS. Usar SOLO en server actions
# y route handlers, nunca en Client Components.
NEXT_SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx


# --- Supabase CLI / migraciones (sólo local, NO va a Vercel) -----------------

# Project ref para `supabase link --project-ref $SUPA_REF`.
SUPA_REF=your_project_ref

# Connection string directa a Postgres (puerto 5432). Se usa para correr
# migraciones desde local en T-009. No se usa desde Vercel.
SUPABASE_DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
